{
  "name": "browser-goblin",
  "version": "0.4.6",
  "description": "A Pi package that gives coding agents a browser goblin for testing, debugging, and visual QA tasks.",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi",
    "browser",
    "browser-automation",
    "playwright",
    "testing",
    "agent-browser"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sagardampba2022w/browser-goblin.git"
  },
  "bugs": {
    "url": "https://github.com/sagardampba2022w/browser-goblin/issues"
  },
  "homepage": "https://github.com/sagardampba2022w/browser-goblin#readme",
  "files": [
    "extensions",
    "skills",
    "assets/preview.png",
    "scripts/smoke-test.sh",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "check": "tsc --noEmit",
    "pack:dry": "npm pack --dry-run",
    "test:smoke": "bash scripts/smoke-test.sh"
  },
  "dependencies": {
    "agent-browser": "latest"
  },
  "devDependencies": {
    "typescript": "^5.8.0",
    "@types/node": "^22.0.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "pi": {
    "extensions": [
      "./extensions/pi-browser/index.ts"
    ],
    "skills": [
      "./skills"
    ],
    "image": "https://raw.githubusercontent.com/sagardampba2022w/browser-goblin/main/assets/preview.png"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  }
}
